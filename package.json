{
  "name": "junai",
  "displayName": "junai - AI Agent Pipeline",
  "description": "AI agent pipeline for GitHub Copilot. Agentic workflow automation with 23 role-scoped agents - architect, implement, test, review. Deterministic. Auditable. From idea to shipped.",
  "version": "0.0.9",
  "publisher": "junai-labs",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other", "AI", "Chat"],
  "keywords": ["ai-pipeline", "agent-pipeline", "ai-agent", "agentic", "copilot-agent", "github-copilot", "multi-agent", "llm", "ai-workflow", "workflow-automation", "pipeline", "orchestration"],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0d0f14",
    "theme": "dark"
  },
  "qna": "https://github.com/saajunaid/junai-vscode/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/saajunaid/junai-vscode"
  },
  "bugs": {
    "url": "https://github.com/saajunaid/junai-vscode/issues"
  },
  "homepage": "https://github.com/saajunaid/junai-vscode#readme",
  "license": "MIT",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServers": {
      "junai": {
        "command": "uvx",
        "args": ["junai-mcp"]
      }
    },
    "commands": [
      {
        "command": "junai.init",
        "title": "Initialize Agent Pipeline",
        "category": "junai"
      },
      {
        "command": "junai.status",
        "title": "Show Pipeline Status",
        "category": "junai"
      },
      {
        "command": "junai.setMode",
        "title": "Set Pipeline Mode",
        "category": "junai"
      },
      {
        "command": "junai.remove",
        "title": "Remove from this project",
        "category": "junai"
      }
    ],
    "configuration": {
      "title": "junai",
      "properties": {
        "junai.defaultMode": {
          "type": "string",
          "enum": ["supervised", "assisted", "autopilot"],
          "default": "supervised",
          "description": "Default pipeline mode for new projects. supervised = all gates manual; assisted = manual gates with AI hints; autopilot = all gates auto-satisfied except intent_approved."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle-pool && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle-pool": "node scripts/bundle-pool.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
