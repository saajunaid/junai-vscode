{
  "name": "junai",
  "displayName": "junai — Agent Pipeline",
  "description": "Drop-in agentic pipelines for any project. From idea to shipped — deterministic, auditable, autonomous.",
  "version": "0.0.1",
  "publisher": "junai-labs",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "keywords": ["agent", "pipeline", "ai", "copilot", "automation", "agentic", "junai"],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/saajunaid/junai-vscode"
  },
  "bugs": {
    "url": "https://github.com/saajunaid/junai-vscode/issues"
  },
  "homepage": "https://github.com/saajunaid/junai-vscode#readme",
  "license": "MIT",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "junai.init",
        "title": "Initialize Agent Pipeline",
        "category": "junai"
      },
      {
        "command": "junai.status",
        "title": "Show Pipeline Status",
        "category": "junai"
      },
      {
        "command": "junai.setMode",
        "title": "Set Pipeline Mode",
        "category": "junai"
      }
    ],
    "configuration": {
      "title": "junai",
      "properties": {
        "junai.defaultMode": {
          "type": "string",
          "enum": ["supervised", "assisted", "autopilot"],
          "default": "supervised",
          "description": "Default pipeline mode for new projects. supervised = all gates manual; assisted = manual gates with AI hints; autopilot = all gates auto-satisfied except intent_approved."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle-pool && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle-pool": "node scripts/bundle-pool.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
